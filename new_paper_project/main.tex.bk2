\title[RA-FA-IQL for V2X]{Risk-Aware Fuzzy-Adaptive Learning for Distributed Load Balancing in Non-Stationary V2X Networks}

\author*[1,2]{\fnm{Antônio Sérgio de Sousa} \sur{Vieira}}\email{sergio.vieira@ifce.edu.br}
